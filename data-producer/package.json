{
  "name": "kucoin-data-producer",
  "version": "1.0.0",
  "description": "Single-producer daemon that fetches KuCoin market data and writes atomically to /dev/shm",
  "private": true,
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev":   "tsx watch src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript":  "^5.5.0"
  }
}
