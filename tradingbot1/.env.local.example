# Copy this file to .env.local and fill in your NEW KuCoin credentials
# NEVER commit .env.local to git

KUCOIN_API_KEY=your_api_key_here
KUCOIN_API_SECRET=your_api_secret_here
KUCOIN_API_PASSPHRASE=your_passphrase_here

# Sandbox for testing (set to https://api.kucoin.com for live)
KUCOIN_BASE_URL=https://api-sandbox.kucoin.com

# Bot config
TRADING_SYMBOL=BTC-USDT
TRADING_INTERVAL=15min
SIGNAL_THRESHOLD=4
MAX_TRADE_USD=500
DAILY_DRAWDOWN_LIMIT=0.05
